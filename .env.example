# ============================================================
# Polymarket BTC 15m Paper Trading Dashboard - Example Config
# ============================================================
#
# 说明：
# 1) 复制本文件为 `.env`
# 2) 填入你自己的密钥 / 钱包 / 参数
# 3) 不要把真实 `.env` 提交到 GitHub
#
# 当前默认工作流：
# - TRADING_MODE=paper_live（模拟交易）
# - bot.py 优先读取 decision_signal.json（通常由 OpenClaw 每 3 分钟写入）
# - 如果没有外部信号，才回退到内置 AI / 规则逻辑
#
# ------------------------------------------------------------
# 1. Polymarket 账户与 API
# ------------------------------------------------------------
# 以下配置通常来自 Polymarket / CLOB 相关后台。
# 即使当前运行 paper trading，项目的一些展示与接口仍会读取这些值。

POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase
POLYMARKET_PRIVATE_KEY=0xyour_private_key
POLYMARKET_WALLET_ADDRESS=0xyour_wallet_address

# 目标市场输入：
# 可填写完整 URL、slug，或某些模式下使用 condition id。
# 当前 paper_live 模式会优先扫描当天 BTC 15m 市场；这个字段主要保留给兼容模式。
BTC_UPDOWN_MARKET_ID=https://polymarket.com/event/your-market-slug

# ------------------------------------------------------------
# 2. 运行模式
# ------------------------------------------------------------
# 可选值：
# - paper_live   : 当前推荐，持续运行的 BTC 15m 模拟交易
# - paper_replay : 历史回放模式
# - live         : 真实交易（默认不建议直接开启）
TRADING_MODE=paper_live

# ------------------------------------------------------------
# 3. 模拟交易基础参数
# ------------------------------------------------------------
PAPER_START_BALANCE=100
PAPER_WALLET_LABEL=LOCAL-SIM-100U
BET_AMOUNT=1
PAPER_BET_AMOUNT=1
MAX_BET_AMOUNT=1

# 最多同时持有几个模拟仓位
PAPER_MAX_OPEN_POSITIONS=1
# 单轮最多新增几个模拟仓位
PAPER_MAX_NEW_POSITIONS_PER_CYCLE=1
# 轮询频率（秒）
PAPER_POLL_INTERVAL_SECONDS=15

# ------------------------------------------------------------
# 4. 模拟交易入场 / 出场条件
# ------------------------------------------------------------
# 只在目标方向 ask 落入这个区间时考虑入场
PAPER_MIN_ENTRY_PRICE=0.15
PAPER_MAX_ENTRY_PRICE=0.70

# 盘口要求
PAPER_MAX_SPREAD=0.10
PAPER_MIN_TOP_BOOK_SIZE=10
PAPER_MIN_MINUTES_TO_EXPIRY=2

# 提前止盈：当 best bid 对应的浮盈超过该值时离场
PAPER_TAKE_PROFIT_USD=0.60

# 兼容保留参数（某些旧模式会读取）
MIN_PROBABILITY_DIFF=0.05
TAKE_PROFIT_PERCENT=0.18
STOP_LOSS_ENABLED=true
STOP_LOSS_PERCENT=0.10
TIME_EXIT_SECONDS=45

# 当前扫描市场的粒度
PAPER_MARKET_INTERVAL_MINUTES=15
# 向后预览多少个未来 slot
PAPER_FORWARD_SLOT_COUNT=8

# ------------------------------------------------------------
# 4b. Hedged Limit 双侧限价策略（默认关闭）
# ------------------------------------------------------------
# 市场选择：
# - auto_btc_15m：沿用原 15m 滚动盘口
# - auto_btc_5m ：扫描 5m 滚动盘口（需要 Polymarket 当前存在该 slug 系列）
MARKET_SELECTION_MODE=auto_btc_15m

# 开启后：先挂一条“锚腿”限价单；首腿成交后，只有当对侧按当前盘口
# 补齐的总成本仍 <=0.97 时，才主动补第二腿锁利。临近结算时若仍未补齐，
# 则单腿离场 / 撤销首腿挂单。live 模式默认不会执行。
HEDGE_LIMIT_ENABLED=false
HEDGE_LIMIT_ALLOW_LIVE=false
# 首腿最高可接受买价上限；实际挂价会贴近 best bid / best ask 动态决定
HEDGE_INITIAL_LIMIT=0.49
HEDGE_MAX_TOTAL_COST=0.97
# 第二腿补齐时的绝对价格上限
HEDGE_MAX_HEDGE_PRICE=0.49
HEDGE_STAKE_PER_LEG=2.0
HEDGE_TARGET_SHARES=0
HEDGE_ENTRY_FRACTION=0.5
HEDGE_ENTRY_TICK_SIZE=0.01
HEDGE_FIRST_LEG_MIN_SECONDS_TO_END=120
HEDGE_CANCEL_PENDING_BEFORE_END_SECONDS=60
HEDGE_SINGLE_EXIT_BEFORE_END_SECONDS=35
HEDGE_MARKET_PREFIX=
BTC_5M_SLUG_PREFIX=btc-updown-5m-
BTC_5M_WINDOW_SECONDS=300

# ------------------------------------------------------------
# 5. BTC 数据源
# ------------------------------------------------------------
# 可选：binance / coingecko
BTC_PRICE_SOURCE=binance

# ------------------------------------------------------------
# Binance 代理配置 (新加坡/云 IP 被 CloudFront 封锁时使用)
# 填 http 或 socks5 代理地址, 留空=直连
# 单个: BINANCE_PROXY_URL=socks5://127.0.0.1:10809
# 池 (轮询 + 失败剔除): BINANCE_PROXY_URLS=socks5://...,socks5://...
BINANCE_PROXY_URL=
BINANCE_PROXY_URLS=socks5://127.0.0.1:10808,socks5://127.0.0.1:10908,socks5://127.0.0.1:11008,socks5://127.0.0.1:11108,socks5://127.0.0.1:11208,socks5://127.0.0.1:11308

# ------------------------------------------------------------
# 6. OpenAI-Compatible AI 配置
# ------------------------------------------------------------
# 如果你不依赖 OpenClaw 外部信号，也可以让项目自己调用 AI。
# 当前 bot.py 支持 OpenAI-compatible chat/completions。

AI_ENABLED=true
AI_DECISION_INTERVAL_SECONDS=180
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_ai_api_key

# MiniMax 兼容：如果你使用 MiniMax，也可以只填写这个键。
# bot.py 会自动在 AI_API_KEY 为空时回退读取 MINIMAX_API_KEY。
MINIMAX_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=700

# ------------------------------------------------------------
# 7. 旧版规则参数（兼容保留）
# ------------------------------------------------------------
AI_UP_THRESHOLD=0.02
AI_DOWN_THRESHOLD=-0.02
MA_PERIOD=5

# ------------------------------------------------------------
# 8. GitHub / 分享前提醒
# ------------------------------------------------------------
# - 不要提交真实 .env
# - 不要公开私钥、API Secret、Passphrase
# - 如果密钥曾暴露，请立即轮换
# - 建议只提交本 .env.example
