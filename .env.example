# FV Edge-only Polymarket bot configuration

# Trading mode: paper_live or live. Live mode also requires DRY_RUN=false.
TRADING_MODE=paper_live
DRY_RUN=true
PAPER_START_BALANCE=100
PAPER_WALLET_LABEL=LOCAL-FV-EDGE

# Polymarket credentials. Never commit real values.
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase
POLYMARKET_PRIVATE_KEY=0xyour_private_key
POLYMARKET_WALLET_ADDRESS=0xyour_wallet_address
POLYMARKET_FUNDER_ADDRESS=0xyour_funder_address
POLYMARKET_SIGNATURE_TYPE=1

# Market discovery
MARKET_SELECTION_MODE=auto_btc_15m
BTC_PRICE_SOURCE=binance
USE_POLYMARKET_WS=true

# FV Edge strategy
FV_EDGE_POSITION_USD=2.0
FV_EDGE_MAX_OPEN_POSITIONS=1
FV_EDGE_THRESHOLD_BPS=300
FV_EDGE_MAX_MTE=2.0
FV_EDGE_MIN_PRICE=0.10
FV_EDGE_MAX_PRICE=0.85
FV_EDGE_MAX_ASK_DRIFT=0.01
FV_EDGE_MAX_BTC_AGE_SECONDS=10
FV_EDGE_MAX_REF_DELAY_SECONDS=10

# Runtime cadence
FV_CYCLE_SECONDS=2
FV_MARKET_REFRESH_SECONDS=10
BTC_PRICE_POLL_SECONDS=2
BTC_SIGNAL_POLL_SECONDS=60

# Optional proxy configuration
BINANCE_PROXY_URL=
BINANCE_PROXY_URLS=

# Dashboard
STATUS_PORT=8889
STATUS_BIND_HOST=127.0.0.1
